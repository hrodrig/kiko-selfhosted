# kiko-selfhosted — template for Docker Compose. Do not commit real secrets.
#
# Recommended host layout:
#   1. export KIKO_HOST_DATA=/home/kiko/kiko-data
#   2. mkdir -p "$KIKO_HOST_DATA/data"
#   3. cp run/common/.env.example "${KIKO_HOST_DATA}/.env" and edit
#   4. docker compose --env-file "${KIKO_HOST_DATA}/.env" \
#        -f run/docker-compose/minimal/docker-compose.yml up -d
#
# Unrelated to kiko-selfhosted VERSION (manifests repo semver).

# --- image ---
# KIKO_IMAGE=registry.example.com/kiko:v0.1.0-dev
KIKO_VERSION=v0.4.0

# Host data directory (absolute path on servers)
# KIKO_HOST_DATA=/home/kiko/kiko-data

# --- kiko app ---
KIKO_LISTEN=:8080
KIKO_PUBLIC_URL=http://localhost:8080
KIKO_LOG_LEVEL=info

# SQLite (default)
KIKO_DATABASE_DRIVER=sqlite
KIKO_DATABASE_PATH=/data/kiko.db

# PostgreSQL (uncomment and set instead of SQLite)
# KIKO_DATABASE_DRIVER=postgres
# KIKO_DATABASE_DSN=postgres://kiko:secret@postgres:5432/kiko?sslmode=disable

# Comma-separated host allowlist (empty = accept all)
# KIKO_ALLOWED_HOSTS=gghstats.com,kzero.dev

KIKO_BUFFER_FLUSH_INTERVAL=10
KIKO_BUFFER_CAPACITY=4096

# Ingest rate limits (per client IP + optional per host)
# KIKO_RATE_LIMIT_ENABLED=true
# KIKO_RATE_LIMIT_REQUESTS_PER_SEC=100
# KIKO_RATE_LIMIT_BURST=200
# KIKO_RATE_LIMIT_HOST_REQUESTS_PER_SEC=50
# KIKO_RATE_LIMIT_HOST_BURST=100

# Filtering (v0.4+) — set trust_proxy when behind Traefik/nginx/Ingress
# KIKO_FILTER_TRUST_PROXY=true
# KIKO_FILTER_BLOCK_BOTS=true
# KIKO_FILTER_BLOCK_PREFETCH=true
# KIKO_FILTER_BLOCK_REFERRER_SPAM=true
# KIKO_FILTER_BLOCK_DATACENTER_IPS=false

# Required in production
# KIKO_VISITOR_SALT=change-me
# KIKO_API_KEY=change-me

# Published host port
KIKO_HOST_PORT=8080
